# Copy to cognee.local.env (gitignored). Mounted as /app/.env inside cognee/cognee.
# CPU path: lumax_cognee_ollama. GPU / shared host Ollama: use host.docker.internal:11434.

STRUCTURED_OUTPUT_FRAMEWORK=BAML
LLM_API_KEY=ollama
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:3b
LLM_ENDPOINT=http://lumax_cognee_ollama:11434/v1

BAML_LLM_PROVIDER=ollama
BAML_LLM_MODEL=llama3.2:3b
BAML_LLM_ENDPOINT=http://lumax_cognee_ollama:11434/v1
BAML_LLM_API_KEY=ollama

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_ENDPOINT=http://lumax_cognee_ollama:11434/api/embeddings
EMBEDDING_DIMENSIONS=768

GRAPH_DATABASE_PROVIDER=kuzu
VECTOR_DB_PROVIDER=lancedb
DB_PROVIDER=sqlite

# Use host Ollama on GPU when soul stack is idle (same endpoints, swap host):
# LLM_ENDPOINT=http://host.docker.internal:11434/v1
# BAML_LLM_ENDPOINT=http://host.docker.internal:11434/v1
# EMBEDDING_ENDPOINT=http://host.docker.internal:11434/api/embeddings
