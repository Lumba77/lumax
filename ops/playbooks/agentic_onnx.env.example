# Lumax sentry agentic self-heal (ONNX-first) example
# Copy relevant keys into your local .env

# Keep preflight + realtime pulse active while app is running.
LUMAX_PREFLIGHT_LEVEL=standard
LUMAX_PREFLIGHT_AUTOHEAL=true

# Agentic solver enabled.
LUMAX_SENTRY_AGENTIC=true

# Force single-provider mode (no fallback model path during deploy/runtime).
LUMAX_SENTRY_SOLVER_MODE=command

# Point to local runner wrapper (inside lumax_ops container).
LUMAX_SENTRY_SOLVER_CMD=python /app/scripts/automation/solver_runner.py --model qwen2.5-coder-3b-instruct-onnx --prompt "{prompt}"

# Optional if your runner executable is not literally "runner".
LUMAX_LOCAL_RUNNER_CMD=runner
LUMAX_LOCAL_RUNNER_TIMEOUT_SEC=20

# Deploy pause controls (set one when rolling out migrations/templates).
# 1) hard pause:
LUMAX_SENTRY_AGENTIC_PAUSED=false
# 2) lockfile pause:
LUMAX_SENTRY_DEPLOY_LOCK_PATH=/tmp/lumax_deploy.lock
# 3) timed pause (unix epoch sec, blank = disabled):
LUMAX_SENTRY_PAUSE_UNTIL_EPOCH=

