[sub_resource type="Shader" id="Shader_meta_pointer"]
code = "shader_type spatial;
render_mode unshaded, cull_disabled, blend_mix, depth_test_disabled, depth_draw_never;

uniform vec4 beam_color : source_color = vec4(1.0, 1.0, 1.0, 0.5);
uniform float beam_len_m = 1.0;
uniform float fade_m = 0.03;

void fragment() {
	float len = max(beam_len_m, 0.06);
	float t = clamp((VERTEX.z + (len * 0.5)) / len, 0.0, 1.0);
	float fade_n = clamp(fade_m / len, 0.02, 0.25);
	float f0 = smoothstep(0.0, fade_n, t);
	float f1 = 1.0 - smoothstep(1.0 - fade_n, 1.0, t);
	float core = max(f0 * f1, 0.45);
	ALBEDO = beam_color.rgb;
	ALPHA = beam_color.a * core;
}
"

