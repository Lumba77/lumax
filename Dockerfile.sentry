FROM python:3.11-slim

WORKDIR /app

# Install ADB for sovereign bridge and Python dependencies
RUN apt-get update && apt-get install -y adb && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir fastapi uvicorn psutil httpx

# Expose Sentry port
EXPOSE 8006

# Run the Sentry service
CMD ["python", "Backend/autonomous_sentry.py"]
