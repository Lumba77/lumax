.env
.env.*
!.env.example
cognee.local.env

# Local Docker BuildKit cache (large; per-machine)
build/docker-buildkit-cache/

# Godot editor binaries dropped in repo root (keep tree clean)
Godot_v4*.exe
Godot_v4*.exe.*
Godot_v4*_console.exe
Godot_v4*_console.exe.*

# Local scratch: screen captures, agent notes, non-app artifacts (see div/files/)
div/

# Python
__pycache__/
*.py[cod]
*$py.class

# Redis runtime dumps (local container data)
**/dump.rdb

# Nested .env (root `.env` rules do not always apply to subdirs in all Git versions)
**/.env

# Cloned upstream (see scripts/bootstrap_chatterbox_resemble.ps1)
tools/Chatterbox-TTS-Server/

# Home Assistant runtime (never commit machine state, DB, or long-lived tokens)
Backend/HomeAssistant/.storage/
Backend/HomeAssistant/secrets.yaml
Backend/HomeAssistant/home-assistant_v2.db
Backend/HomeAssistant/home-assistant_v2.db-shm
Backend/HomeAssistant/home-assistant_v2.db-wal
Backend/HomeAssistant/home-assistant.log
Backend/HomeAssistant/home-assistant.log.*
Backend/HomeAssistant/home-assistant.log.fault
Backend/HomeAssistant/.ha_run.lock

# Tailscale node state (keys / DERP map cache)
Backend/tailscale/state/
