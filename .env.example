# Copy to `.env` if you want to override defaults (Compose loads `.env` automatically).

# Host path to InvokeAI `models` folder (bind-mounted into creativity container as /invokeai/models).
# Default in compose is an empty repo stub so the stack starts everywhere; set this to your real InvokeAI models dir.
# LUMAX_INVOKEAI_MODELS_HOST=D:/Lumax/InvokeAI/models
# LUMAX_INVOKEAI_MODELS_HOST=C:/Users/you/AppData/Local/InvokeAI/models
# LUMAX_INVOKEAI_MODELS_HOST=/home/you/InvokeAI/models
#
# Merge SD1.x ControlNet entries from tools/invokeai_models_inventory.csv (default on). Opt out: LUMAX_INVOKEAI_MERGE_CONTROLNETS=0
# LUMAX_INVOKEAI_MERGE_CONTROLNETS=1

# Advanced only: bind-mount Invoke's venv site-packages into the container, then e.g.
# LUMAX_INVOKEAI_PYTHONPATH=/invokeai/site-packages
# (Python major.minor and PyTorch builds must match the container or imports will break.)

# --- lumax_ops / AutonomousSentry agentic solver (same LUMAX_REPERTOIRE_* keys as lumax_soul) ---
# Use cloud APIs for watchdog JSON decisions instead of local command/Ollama:
# LUMAX_SENTRY_SOLVER_MODE=repertoire
# Slot: gemini | openai | extra | rotate | auto  (rotate/auto pick among configured slots; OpenAI respects LUMAX_OPENAI_DAILY_MAX_REQUESTS)
# LUMAX_SENTRY_REPERTOIRE_SLOT=gemini
# Smaller completions for heal prompts (default 768):
# LUMAX_SENTRY_REPERTOIRE_MAX_TOKENS=768
# Keys/models are shared with soul — set LUMAX_REPERTOIRE_GEMINI_API_KEY (etc.) once in .env; compose passes them into lumax_ops.

# --- Global paid GenAI (Her-style scarcity: plan before burning cloud) ---
# Counts successful OpenAI-compatible /chat/completions (all repertoire slots + sentry repertoire mode).
# Ollama/local GGUF does not increment. Default 0 = unlimited. Suggested tight stack: 10
# LUMAX_CLOUD_GENAI_DAILY_MAX=10
# Optional: explicit counter file (default is Backend/preflight/outbox/genai_daily_usage.json on the repo mount)
# LUMAX_CLOUD_GENAI_USAGE_PATH=/app/Backend/preflight/outbox/genai_daily_usage.json

# Mobile / Capacitor dev: allow Vite origin to call lumax_ops with session cookies (comma-separated).
# LUMAX_WEBUI_CORS_ORIGINS=http://192.168.1.10:5173
